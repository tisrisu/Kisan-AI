# ── ML model weights (large binary files) ────────────────────────
# Commit adapter_config.json but NOT the heavy weight files
models/base/*.pth
models/base/*.pt
models/lora_adapters/**/*.safetensors
models/lora_adapters/**/*.bin
# Exception: keep the district-specific adapter configs
!models/lora_adapters/**/adapter_config.json


# ──────────────────────────────────────────────────────────────
# KisanAI — Environment Variables
#
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# .env is git-ignored. NEVER commit actual credentials.
# ──────────────────────────────────────────────────────────────

# ── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_USER=kisanai
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=kisanai_db

# ── MinIO (S3-compatible object storage) ───────────────────────
MINIO_ROOT_USER=kisanai_minio
MINIO_ROOT_PASSWORD=change_me_minio_password

# ── FastAPI Backend ─────────────────────────────────────────────
# Overrides config.py defaults when running with Docker
DATABASE_URL=postgresql+asyncpg://kisanai:change_me_strong_password@postgres:5432/kisanai_db
REDIS_URL=redis://redis:6379/0
DEBUG=false

# ── Next.js Frontend ────────────────────────────────────────────
# Public env vars (safe to expose to browser)
NEXT_PUBLIC_API_URL=http://localhost:8000
